---
import Layout from "@/layouts/Layout.astro";
import { getReadme } from "@/lib/github";
import Head from "@/components/head-page.astro";
const { html, etag } = await getReadme();

Astro.cache.set({
  maxAge: 60,
  swr: 30,
  tags: ["home"],
});
---

<Layout>
  <Head slot="head" title="Home" />
  <div set:html={html} />
</Layout>

<style is:global>
  a[id^="user-content-"].anchor {
    display: none !important;
  }
</style>
